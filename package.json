{
  "name": "code-commands",
  "displayName": "Code Commands",
  "description": "Manage and execute your custom project commands globally in VS Code.",
  "version": "0.0.2",
  "publisher": "NicolasXs",
  "icon": "media/icon.png",
  "engines": {
    "vscode": ">=1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "configuration": {
      "title": "Code Commands",
      "properties": {
        "code-commands.groups": {
          "type": "array",
          "default": [
            {
              "id": "default",
              "name": "Default",
              "commands": []
            }
          ],
          "description": "List of command groups with their commands.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "collapsed": {
                "type": "boolean"
              },
              "commands": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "label": {
                      "type": "string"
                    },
                    "command": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeCommands",
          "title": "Code Commands",
          "icon": "media/terminal.svg"
        }
      ]
    },
    "views": {
      "codeCommands": [
        {
          "id": "commandsView",
          "name": "Code Commands"
        }
      ]
    },
    "commands": [
      {
        "command": "code-commands.addCommand",
        "title": "Add New Command",
        "category": "Code Commands"
      },
      {
        "command": "code-commands.runCommand",
        "title": "Run",
        "category": "Code Commands",
        "icon": {
          "light": "media/play.svg",
          "dark": "media/play.svg"
        }
      },
      {
        "command": "code-commands.editCommand",
        "title": "Edit Command",
        "category": "Code Commands",
        "icon": {
          "light": "media/edit.svg",
          "dark": "media/edit.svg"
        }
      },
      {
        "command": "code-commands.removeCommand",
        "title": "Remove Command",
        "category": "Code Commands",
        "icon": {
          "light": "media/delete.svg",
          "dark": "media/delete.svg"
        }
      },
      {
        "command": "code-commands.refreshView",
        "title": "Refresh Commands",
        "category": "Code Commands",
        "icon": "$(refresh)"
      },
      {
        "command": "code-commands.addGroup",
        "title": "Add New Group",
        "category": "Code Commands",
        "icon": "$(add)"
      },
      {
        "command": "code-commands.renameGroup",
        "title": "Rename Group",
        "category": "Code Commands",
        "icon": {
          "light": "media/edit.svg",
          "dark": "media/edit.svg"
        }
      },
      {
        "command": "code-commands.removeGroup",
        "title": "Remove Group",
        "category": "Code Commands",
        "icon": {
          "light": "media/delete.svg",
          "dark": "media/delete.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "code-commands.addGroup",
          "when": "view == commandsView",
          "group": "navigation"
        },
        {
          "command": "code-commands.refreshView",
          "when": "view == commandsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "code-commands.addCommand",
          "when": "view == commandsView && viewItem == commandGroup",
          "group": "inline@1"
        },
        {
          "command": "code-commands.runCommand",
          "when": "view == commandsView && viewItem == commandItem",
          "group": "inline@1"
        },
        {
          "command": "code-commands.editCommand",
          "when": "view == commandsView && viewItem == commandItem",
          "group": "inline@2"
        },
        {
          "command": "code-commands.removeCommand",
          "when": "view == commandsView && viewItem == commandItem",
          "group": "inline@3"
        },
        {
          "command": "code-commands.renameGroup",
          "when": "view == commandsView && viewItem == commandGroup",
          "group": "inline@2"
        },
        {
          "command": "code-commands.removeGroup",
          "when": "view == commandsView && viewItem == commandGroup",
          "group": "inline@3"
        }
      ]
    }
  },
  "activationEvents": [
    "onView:commandsView"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NicolasXs/code-commands.git"
  }
}
